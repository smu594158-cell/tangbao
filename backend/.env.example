# Server Configuration
SERVER_PORT=:8080

# MySQL Database
# Format: user:password@tcp(host:port)/dbname?charset=utf8mb4&parseTime=True&loc=Local
DB_DSN=hztour_user:hztour_password@tcp(127.0.0.1:3306)/hztour_db?charset=utf8mb4&parseTime=True&loc=Local

# Ollama Model Config
OLLAMA_BASE_URL=http://127.0.0.1:11434

# Amap (高德地图) Web API Key
# 替换为你自己在高德开放平台申请的 Web 服务 API Key
AMAP_WEB_KEY=your_amap_web_api_key_here
